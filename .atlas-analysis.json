  "keyFeatures": [
    "Parallel execution of multiple coding agents in isolated git worktrees",
    "Support for 22+ CLI providers (Claude Code, Codex, Qwen, Amp, etc.)",
    "Remote development over SSH",
    "Cross-agent skills system based on Agent Skills standard",
    "Integrations with Linear, Jira, and GitHub Issues",
    "Real-time terminal and diff visualization",
    "Automated PR generation and CI/CD integration",
    "Worktree pooling for instant task starts"
  ],
  "publicApiSurface": [
    "WorktreeService - Git worktree lifecycle management",
    "WorktreePoolService - Worktree pooling and reuse",
    "DatabaseService - SQLite CRUD operations",
    "ptyManager - PTY lifecycle and agent spawning",
    "SkillsService - Cross-agent skill management",
    "GitHubService - Git and GitHub operations",
    "PrGenerationService - Automated PR generation",
    "RemotePtyService - Remote development over SSH",
    "ConnectionsService - SSH connection management",
    "LinearService - Linear integration",
    "JiraService - Jira integration",
    "Provider Registry - 22 CLI agent definitions",
    "IPC Handlers - 25+ handlers for app, db, git, github, ssh, etc."
  ]
